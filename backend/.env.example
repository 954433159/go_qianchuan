# 千川API配置
APP_ID=你的千川AppID
APP_SECRET=你的千川AppSecret

# 服务器配置
PORT=8080
GIN_MODE=debug

# CORS配置
CORS_ORIGIN=http://localhost:3000

# Cookie配置
COOKIE_SECRET=请生成一个随机密钥_至少32字符
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=lax

# Session配置
SESSION_TTL=86400
SESSION_NAME=qianchuan_session

# 日志配置
LOG_LEVEL=debug
