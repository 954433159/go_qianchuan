# Backend Production Configuration\n# 后端生产环境配置（请使用密钥管理服务）\n\n# ⚠️ IMPORTANT: Use secure credential management in production!\n# Qianchuan API Configuration\nAPP_ID={{APP_ID}}          # Set via environment variable or secret management\nAPP_SECRET={{APP_SECRET}}  # Set via environment variable or secret management\n\n# Server Configuration\nPORT=8080\nGIN_MODE=release\n\n# CORS Configuration (comma-separated list supported)\nCORS_ORIGIN=https://yourdomain.com\n\n# Cookie Configuration\nCOOKIE_SECRET={{COOKIE_SECRET}}  # Generate random 32+ char string\nCOOKIE_DOMAIN=yourdomain.com\nCOOKIE_SECURE=true              # Must be true in HTTPS\nCOOKIE_HTTP_ONLY=true\nCOOKIE_SAME_SITE=strict\n\n# Session Configuration\nSESSION_TTL=3600               # 1 hour\nSESSION_NAME=qianchuan_session\n\n# Logging Configuration\nLOG_LEVEL=warn\n"}