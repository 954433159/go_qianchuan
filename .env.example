# =================================================================
# 千川SDK管理平台 - 环境变量配置模板
# =================================================================
# 重要说明：
# 1. 复制此文件为 .env 并填入真实值
# 2. 绝不要将 .env 文件提交到 Git
# 3. 已添加到 .gitignore 中，会自动忽略

# Qianchuan API 配置 (必需)
APP_ID=your_qianchuan_app_id
APP_SECRET=your_qianchuan_app_secret

# 服务器配置 (必需)
PORT=8080
GIN_MODE=debug
CORS_ORIGIN=http://localhost:3000

# Cookie 和 Session 配置 (必需)
COOKIE_SECRET=your_random_32_byte_secret_here
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
SESSION_NAME=qianchuan_session

# 前端配置 (必需)
VITE_API_BASE_URL=http://localhost:8080/api
VITE_OAUTH_APP_ID=your_oauth_app_id
VITE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/callback
VITE_APP_TITLE=千川SDK管理平台

# MCP 服务器环境变量 (可选)
GITHUB_TOKEN=your_github_personal_access_token
STRIPE_SECRET_KEY=your_stripe_secret_key
FIGMA_ACCESS_TOKEN=your_figma_access_token
POSTGRES_URL=postgresql://username:password@localhost:5432/database
SEMANTIC_SCHOLAR_API_KEY=your_semantic_scholar_api_key

# 华为云MCP自动化部署配置 (可选)
# 从华为云控制台获取：我的凭证 -> API凭证 -> 创建凭证
HUAWEICLOUD_ACCESS_KEY=your_huaweicloud_access_key
HUAWEICLOUD_SECRET_KEY=your_huaweicloud_secret_key
# 区域示例：cn-north-1, cn-north-9, cn-south-1
HUAWEICLOUD_REGION=cn-north-1
# 项目ID获取：我的凭证 -> 项目列表
HUAWEICLOUD_PROJECT_ID=your_project_id
# ECS实例配置（推荐设置）
HUAWEICLOUD_SECURITY_GROUP_ID=your_security_group_id
HUAWEICLOUD_SUBNET_ID=your_subnet_id
# OBS存储配置（可选）
HUAWEICLOUD_DEFAULT_BUCKET=your_default_bucket_name
