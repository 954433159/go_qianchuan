<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <link rel="stylesheet" href="./design-system.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>直播间商品销售详情 - 千川直播带货平台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>
<body class="bg-gray-50">
      <!-- Header -->
  <header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-gray-200">
    <div class="flex h-16 items-center justify-between px-6">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-red-500 to-orange-500">
          <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="hidden md:block">
          <h1 class="text-lg font-bold text-gray-900">千川直播带货</h1>
          <p class="text-xs text-gray-500">Qianchuan Live E-commerce</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button class="relative flex items-center justify-center w-10 h-10 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <span class="absolute right-1.5 top-1.5 h-2 w-2 rounded-full bg-red-500"></span>
        </button>
        <div class="relative">
          <button class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-100 transition-colors">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-red-500 to-orange-500 text-white">
              <span class="text-sm font-medium">商</span>
            </div>
            <span class="hidden text-sm font-medium md:inline-block">商家中心</span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <div class="flex">
    <aside class="w-64 bg-white border-r border-gray-200 min-h-[calc(100vh-64px)] sticky top-16">
      <nav id="main-nav" class="p-4 space-y-6"></nav>
    </aside>

    <main class="flex-1 p-8">
      <div class="max-w-7xl mx-auto space-y-6">
<div class="flex">
        <aside class="w-64 bg-white border-r border-gray-200 min-h-[calc(100vh-64px)] sticky top-16">
            <nav class="p-4 space-y-6">
                <div>
                    <h3 class="mb-3 px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">数据报表</h3>
                    <ul class="space-y-1">
                        <li>
                            <a href="reports.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <span>报表中心</span>
                            </a>
                        </li>
                        <li>
                            <a href="live-rooms.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <span>直播间报表</span>
                            </a>
                        </li>
                        <li>
                            <a href="report-live-product-detail.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg bg-gradient-to-r from-red-500 to-orange-500 text-white font-medium shadow-sm">
                                <span>商品销售详情</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
        </aside>

        <main class="flex-1 p-8">
            <div class="max-w-7xl mx-auto space-y-6">
                <div class="flex items-center text-sm text-gray-500">
                    <a href="dashboard.html" class="hover:text-blue-600">数据中心</a>
                    <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                    <a href="reports.html" class="hover:text-blue-600">数据报表</a>
                    <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                    <span class="text-gray-900">直播间商品销售详情</span>
                </div>

                <div>
                    <h1 class="text-3xl font-bold text-gray-900">直播间商品销售详情报表</h1>
                    <p class="mt-2 text-gray-600">查看直播间商品的详细销售数据和趋势分析</p>
                </div>

                <!-- Filters -->
                <div class="bg-white rounded-lg border border-gray-200 p-6">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">筛选条件</h2>
                    <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">直播间</label>
                            <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                                <option>美妆旗舰店</option>
                                <option>服饰专卖店</option>
                                <option>食品优选馆</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">日期范围</label>
                            <input type="date" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">商品分类</label>
                            <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                                <option>全部分类</option>
                                <option>服饰</option>
                                <option>美妆</option>
                                <option>食品</option>
                            </select>
                        </div>
                        <div class="flex items-end">
                            <button class="w-full px-4 py-2 bg-gradient-to-r from-red-500 to-orange-500 text-white rounded-lg hover:from-red-600 hover:to-orange-600 transition-all shadow-sm">
                                查询
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Summary Cards -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <p class="text-sm font-medium text-gray-600 mb-2">商品总GMV</p>
                        <p class="text-3xl font-bold text-gray-900">¥128.4K</p>
                        <p class="text-sm text-green-600 mt-2">+15.3% vs 昨日</p>
                    </div>
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <p class="text-sm font-medium text-gray-600 mb-2">销售件数</p>
                        <p class="text-3xl font-bold text-gray-900">1,234</p>
                        <p class="text-sm text-green-600 mt-2">+12.8% vs 昨日</p>
                    </div>
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <p class="text-sm font-medium text-gray-600 mb-2">商品点击率</p>
                        <p class="text-3xl font-bold text-gray-900">8.5%</p>
                        <p class="text-sm text-green-600 mt-2">+1.2% vs 昨日</p>
                    </div>
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <p class="text-sm font-medium text-gray-600 mb-2">平均客单价</p>
                        <p class="text-3xl font-bold text-gray-900">¥104</p>
                        <p class="text-sm text-orange-600 mt-2">+2.1% vs 昨日</p>
                    </div>
                </div>

                <!-- Product Sales Table -->
                <div class="bg-white rounded-lg border border-gray-200 p-6">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">商品销售明细</h2>
                    <div class="overflow-x-auto">
                        <table class="w-full">
                            <thead class="bg-gray-50 border-b border-gray-200">
                                <tr>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">排名</th>
                                    <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">商品信息</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">GMV</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">销量</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">点击量</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">转化率</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">客单价</th>
                                    <th class="px-4 py-3 text-right text-xs font-medium text-gray-500 uppercase">操作</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-gray-200">
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-4 text-2xl">🥇</td>
                                    <td class="px-4 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-16 h-16 bg-gradient-to-br from-pink-100 to-orange-100 rounded"></div>
                                            <div>
                                                <p class="text-sm font-medium text-gray-900">[限时特价] 冬季保暖羽绒服</p>
                                                <p class="text-xs text-gray-500">商品ID: PROD123456</p>
                                                <span class="inline-block mt-1 px-2 py-0.5 bg-orange-100 text-orange-700 text-xs rounded">限时特价</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 py-4 text-right text-sm font-bold text-orange-600">¥45.6K</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">152</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">1,789</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">8.5%</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">¥300</td>
                                    <td class="px-4 py-4 text-right">
                                        <button class="text-sm text-blue-600 hover:text-blue-700">详情</button>
                                    </td>
                                </tr>
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-4 text-2xl">🥈</td>
                                    <td class="px-4 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-16 h-16 bg-gradient-to-br from-purple-100 to-pink-100 rounded"></div>
                                            <div>
                                                <p class="text-sm font-medium text-gray-900">口红套装礼盒</p>
                                                <p class="text-xs text-gray-500">商品ID: PROD123457</p>
                                                <span class="inline-block mt-1 px-2 py-0.5 bg-pink-100 text-pink-700 text-xs rounded">热销</span>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 py-4 text-right text-sm font-bold text-orange-600">¥38.2K</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">128</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">2,065</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">6.2%</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">¥298</td>
                                    <td class="px-4 py-4 text-right">
                                        <button class="text-sm text-blue-600 hover:text-blue-700">详情</button>
                                    </td>
                                </tr>
                                <tr class="hover:bg-gray-50">
                                    <td class="px-4 py-4 text-2xl">🥉</td>
                                    <td class="px-4 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-16 h-16 bg-gradient-to-br from-green-100 to-teal-100 rounded"></div>
                                            <div>
                                                <p class="text-sm font-medium text-gray-900">智能保温杯</p>
                                                <p class="text-xs text-gray-500">商品ID: PROD123458</p>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-4 py-4 text-right text-sm font-bold text-orange-600">¥32.1K</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">268</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">2,945</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">9.1%</td>
                                    <td class="px-4 py-4 text-right text-sm text-gray-900">¥120</td>
                                    <td class="px-4 py-4 text-right">
                                        <button class="text-sm text-blue-600 hover:text-blue-700">详情</button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- Charts -->
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <h2 class="text-lg font-semibold text-gray-900 mb-4">商品GMV趋势</h2>
                        <div class="h-80">
                            <canvas id="gmvChart"></canvas>
                        </div>
                    </div>
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <h2 class="text-lg font-semibold text-gray-900 mb-4">商品销量分布</h2>
                        <div class="h-80">
                            <canvas id="salesChart"></canvas>
                        </div>
                    </div>
                </div>
            </div>
              </div>
    </div>
  </main>
  </div>
    </div>

    <script>
        // GMV Trend Chart
        const ctxGMV = document.getElementById('gmvChart').getContext('2d');
        new Chart(ctxGMV, {
            type: 'line',
            data: {
                labels: ['00:00', '03:00', '06:00', '09:00', '12:00', '15:00', '18:00', '21:00', '24:00'],
                datasets: [
                    {
                        label: '羽绒服',
                        data: [2.5, 3.2, 5.1, 7.8, 12.3, 15.6, 18.2, 22.5, 23.1],
                        borderColor: 'rgb(249, 115, 22)',
                        backgroundColor: 'rgba(249, 115, 22, 0.1)',
                        tension: 0.4,
                        fill: true
                    },
                    {
                        label: '口红套装',
                        data: [1.8, 2.5, 3.8, 6.2, 9.5, 12.8, 15.2, 17.8, 18.2],
                        borderColor: 'rgb(236, 72, 153)',
                        backgroundColor: 'rgba(236, 72, 153, 0.1)',
                        tension: 0.4,
                        fill: true
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'top',
                    }
                }
            }
        });

        // Sales Distribution Chart
        const ctxSales = document.getElementById('salesChart').getContext('2d');
        new Chart(ctxSales, {
            type: 'bar',
            data: {
                labels: ['羽绒服', '口红套装', '保温杯', '零食包', '面膜'],
                datasets: [{
                    label: '销量',
                    data: [152, 128, 268, 185, 143],
                    backgroundColor: [
                        'rgba(249, 115, 22, 0.8)',
                        'rgba(236, 72, 153, 0.8)',
                        'rgba(16, 185, 129, 0.8)',
                        'rgba(59, 130, 246, 0.8)',
                        'rgba(147, 51, 234, 0.8)'
                    ]
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        display: false
                    }
                }
            }
        });
    </script>
  <script src="nav-component.js"></script>
</body>
</html>
