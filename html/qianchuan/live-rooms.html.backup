<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <link rel="stylesheet" href="./design-system.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>直播间管理 - 千川直播带货平台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        @keyframes live-pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        .live-dot { animation: live-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Header -->
  <header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-gray-200">
    <div class="flex h-16 items-center justify-between px-6">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-red-500 to-orange-500">
          <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="hidden md:block">
          <h1 class="text-lg font-bold text-gray-900">千川直播带货</h1>
          <p class="text-xs text-gray-500">Qianchuan Live E-commerce</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button class="relative flex items-center justify-center w-10 h-10 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <span class="absolute right-1.5 top-1.5 h-2 w-2 rounded-full bg-red-500"></span>
        </button>
        <div class="relative">
          <button class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-100 transition-colors">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-red-500 to-orange-500 text-white">
              <span class="text-sm font-medium">商</span>
            </div>
            <span class="hidden text-sm font-medium md:inline-block">商家中心</span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <div class="flex">
    <aside class="w-64 bg-white border-r border-gray-200 min-h-[calc(100vh-64px)] sticky top-16">
      <nav id="main-nav" class="p-4 space-y-6"></nav>
    </aside>

    <main class="flex-1 p-8">
      <div class="max-w-7xl mx-auto space-y-6">
<div class="flex">
        <!-- Sidebar -->
        <aside class="w-64 bg-white border-r border-gray-200 min-h-[calc(100vh-64px)] sticky top-16">
            <nav class="p-4 space-y-6">
                <div>
                    <h3 class="mb-3 px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">数据中心</h3>
                    <ul class="space-y-1">
                        <li>
                            <a href="dashboard.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
                                </svg>
                                <span>实时数据</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <div>
                    <h3 class="mb-3 px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">账号管理</h3>
                    <ul class="space-y-1">
                        <li>
                            <a href="aweme-accounts.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                                </svg>
                                <span>抖音号管理</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <div>
                    <h3 class="mb-3 px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">直播管理</h3>
                    <ul class="space-y-1">
                        <li>
                            <a href="live-rooms.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg bg-gradient-to-r from-red-500 to-orange-500 text-white font-medium shadow-sm">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                                </svg>
                                <span>直播间</span>
                                <span class="ml-auto px-2 py-0.5 text-xs font-medium bg-red-100 text-red-600 rounded-full">3</span>
                            </a>
                        </li>
                        <li>
                            <a href="live-data.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/>
                                </svg>
                                <span>直播数据</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <div>
                    <h3 class="mb-3 px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">商品管理</h3>
                    <ul class="space-y-1">
                        <li>
                            <a href="products.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
                                </svg>
                                <span>商品库</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <div>
                    <h3 class="mb-3 px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">推广投放</h3>
                    <ul class="space-y-1">
                        <li>
                            <a href="promotions.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                                </svg>
                                <span>推广计划</span>
                            </a>
                        </li>
                        <li>
                            <a href="creatives.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
                                </svg>
                                <span>创意管理</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <div>
                    <h3 class="mb-3 px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">素材中心</h3>
                    <ul class="space-y-1">
                        <li>
                            <a href="media-library.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                                </svg>
                                <span>媒体库</span>
                            </a>
                        </li>
                    </ul>
                </div>

                <div>
                    <h3 class="mb-3 px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">定向工具</h3>
                    <ul class="space-y-1">
                        <li>
                            <a href="audiences.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
                                </svg>
                                <span>人群包</span>
                            </a>
                        </li>
                        <li>
                            <a href="tools-targeting.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                                <span>定向工具</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-7xl mx-auto space-y-6">
                <!-- Page Header -->
                <div class="flex items-center justify-between">
                    <div>
                        <div class="flex items-center text-sm text-gray-500 mb-2">
                            <a href="dashboard.html" class="hover:text-blue-600">数据中心</a>
                            <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                            </svg>
                            <span class="text-gray-900">直播间管理</span>
                        </div>
                        <h1 class="text-3xl font-bold text-gray-900">我的直播间</h1>
                        <p class="mt-2 text-gray-600">管理和监控所有直播间的推广情况</p>
                    </div>
                    <button class="flex items-center gap-2 px-4 py-2 bg-gradient-to-r from-red-500 to-orange-500 text-white rounded-lg hover:from-red-600 hover:to-orange-600 transition-all shadow-sm">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"/>
                        </svg>
                        <span>新建推广计划</span>
                    </button>
                </div>

                <!-- Filters -->
                <div class="bg-white rounded-lg border border-gray-200 p-4">
                    <div class="flex flex-wrap gap-4 items-center">
                        <div class="flex items-center gap-2">
                            <span class="text-sm font-medium text-gray-700">状态:</span>
                            <div class="flex gap-2">
                                <button class="px-3 py-1.5 text-sm font-medium bg-gradient-to-r from-red-500 to-orange-500 text-white rounded-lg">全部 (14)</button>
                                <button class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">🔴 直播中 (3)</button>
                                <button class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">⚫ 未开播 (5)</button>
                                <button class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">📅 预告 (2)</button>
                                <button class="px-3 py-1.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50">📊 已结束 (4)</button>
                            </div>
                        </div>
                        <div class="flex-1"></div>
                        <div class="flex items-center gap-2">
                            <input type="text" placeholder="搜索直播间名称或主播..." class="px-4 py-2 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-red-500 w-80">
                            <button class="px-4 py-2 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 text-sm font-medium">
                                搜索
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Live Rooms List -->
                <div class="space-y-4">
                    <!-- Live Room Card 1 - 直播中 -->
                    <div class="bg-white rounded-lg border-2 border-red-200 shadow-sm hover:shadow-md transition-shadow">
                        <div class="p-6">
                            <div class="flex items-start gap-6">
                                <!-- Live Room Thumbnail -->
                                <div class="relative flex-shrink-0">
                                    <div class="w-48 h-32 bg-gradient-to-br from-red-100 to-orange-100 rounded-lg flex items-center justify-center">
                                        <svg class="w-16 h-16 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                                        </svg>
                                    </div>
                                    <div class="absolute top-2 left-2 flex items-center gap-1 px-2 py-1 bg-red-500 text-white rounded text-xs font-medium">
                                        <span class="live-dot h-1.5 w-1.5 rounded-full bg-white"></span>
                                        直播中
                                    </div>
                                    <div class="absolute top-2 right-2 px-2 py-1 bg-black/60 text-white rounded text-xs font-medium">
                                        3:24:15
                                    </div>
                                </div>

                                <!-- Live Room Info -->
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-start justify-between mb-3">
                                        <div>
                                            <div class="flex items-center gap-2 mb-1">
                                                <h3 class="text-lg font-semibold text-gray-900">🛍️ 美妆旗舰店 - 限时特惠专场</h3>
                                                <span class="px-2 py-0.5 text-xs font-medium bg-red-500 text-white rounded">热推中</span>
                                            </div>
                                            <p class="text-sm text-gray-600">主播: 小美 @xiaomei123 | 房间号: 8869457221</p>
                                        </div>
                                    </div>

                                    <!-- Real-time Data -->
                                    <div class="bg-gradient-to-r from-red-50 to-orange-50 rounded-lg p-4 mb-4">
                                        <div class="grid grid-cols-2 lg:grid-cols-6 gap-4">
                                            <div>
                                                <p class="text-xs text-gray-600 mb-1">观看人数</p>
                                                <p class="text-[10px] text-gray-400 mb-1">watch_cnt</p>
                                                <p class="text-lg font-bold text-gray-900">8.5K</p>
                                            </div>
                                            <div>
                                                <p class="text-xs text-gray-600 mb-1">今日GMV</p>
                                                <p class="text-[10px] text-gray-400 mb-1">pay_order_amount</p>
                                                <p class="text-lg font-bold text-orange-600">¥45K</p>
                                            </div>
                                            <div>
                                                <p class="text-xs text-gray-600 mb-1">成交订单</p>
                                                <p class="text-[10px] text-gray-400 mb-1">pay_order_count</p>
                                                <p class="text-lg font-bold text-gray-900">234</p>
                                            </div>
                                            <div>
                                                <p class="text-xs text-gray-600 mb-1">点赞数</p>
                                                <p class="text-[10px] text-gray-400 mb-1">like_cnt</p>
                                                <p class="text-lg font-bold text-gray-900">45.6K</p>
                                            </div>
                                            <div>
                                                <p class="text-xs text-gray-600 mb-1">评论数</p>
                                                <p class="text-[10px] text-gray-400 mb-1">comment_cnt</p>
                                                <p class="text-lg font-bold text-gray-900">2.3K</p>
                                            </div>
                                            <div>
                                                <p class="text-xs text-gray-600 mb-1">分享数</p>
                                                <p class="text-[10px] text-gray-400 mb-1">share_cnt</p>
                                                <p class="text-lg font-bold text-gray-900">892</p>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 流量来源分析 -->
                                    <div class="bg-white rounded-lg border border-gray-200 p-4 mb-4">
                                        <h4 class="text-sm font-semibold text-gray-900 mb-3">💰 流量来源分析 <span class="text-xs text-gray-500">(traffic_source)</span></h4>
                                        <div class="grid grid-cols-3 gap-3">
                                            <div class="text-center p-3 bg-blue-50 rounded-lg">
                                                <p class="text-xs text-gray-600 mb-1">自然流量</p>
                                                <p class="text-lg font-bold text-blue-600">45%</p>
                                                <p class="text-xs text-gray-500">3.8K人</p>
                                            </div>
                                            <div class="text-center p-3 bg-red-50 rounded-lg">
                                                <p class="text-xs text-gray-600 mb-1">付费流量</p>
                                                <p class="text-lg font-bold text-red-600">35%</p>
                                                <p class="text-xs text-gray-500">3.0K人</p>
                                            </div>
                                            <div class="text-center p-3 bg-purple-50 rounded-lg">
                                                <p class="text-xs text-gray-600 mb-1">推荐流量</p>
                                                <p class="text-lg font-bold text-purple-600">20%</p>
                                                <p class="text-xs text-gray-500">1.7K人</p>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- 用户画像 -->
                                    <div class="bg-white rounded-lg border border-gray-200 p-4 mb-4">
                                        <h4 class="text-sm font-semibold text-gray-900 mb-3">👥 用户画像 <span class="text-xs text-gray-500">(user_profile)</span></h4>
                                        <div class="grid grid-cols-3 gap-3">
                                            <div>
                                                <p class="text-xs text-gray-600 mb-2">年龄分布</p>
                                                <div class="space-y-1">
                                                    <div class="flex items-center justify-between text-xs">
                                                        <span class="text-gray-600">18-24岁</span>
                                                        <span class="font-medium text-gray-900">28%</span>
                                                    </div>
                                                    <div class="w-full bg-gray-200 rounded-full h-1.5">
                                                        <div class="bg-gradient-to-r from-red-500 to-orange-500 h-1.5 rounded-full" style="width: 28%"></div>
                                                    </div>
                                                    <div class="flex items-center justify-between text-xs">
                                                        <span class="text-gray-600">25-34岁</span>
                                                        <span class="font-medium text-gray-900">45%</span>
                                                    </div>
                                                    <div class="w-full bg-gray-200 rounded-full h-1.5">
                                                        <div class="bg-gradient-to-r from-red-500 to-orange-500 h-1.5 rounded-full" style="width: 45%"></div>
                                                    </div>
                                                    <div class="flex items-center justify-between text-xs">
                                                        <span class="text-gray-600">35岁以上</span>
                                                        <span class="font-medium text-gray-900">27%</span>
                                                    </div>
                                                    <div class="w-full bg-gray-200 rounded-full h-1.5">
                                                        <div class="bg-gradient-to-r from-red-500 to-orange-500 h-1.5 rounded-full" style="width: 27%"></div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div>
                                                <p class="text-xs text-gray-600 mb-2">性别分布</p>
                                                <div class="flex items-center gap-3">
                                                    <div class="flex-1 text-center p-2 bg-pink-50 rounded">
                                                        <p class="text-xs text-gray-600">女性</p>
                                                        <p class="text-lg font-bold text-pink-600">72%</p>
                                                    </div>
                                                    <div class="flex-1 text-center p-2 bg-blue-50 rounded">
                                                        <p class="text-xs text-gray-600">男性</p>
                                                        <p class="text-lg font-bold text-blue-600">28%</p>
                                                    </div>
                                                </div>
                                            </div>
                                            <div>
