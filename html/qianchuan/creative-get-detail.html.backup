<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <link rel="stylesheet" href="./design-system.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>创意详情 - 千川直播带货平台</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <style>
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #f1f5f9; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
        
        @keyframes status-pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.5; }
        }
        .status-indicator { animation: status-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
    </style>
</head>
<body class="bg-gray-50">
    <!-- Header -->
  <header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-gray-200">
    <div class="flex h-16 items-center justify-between px-6">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-red-500 to-orange-500">
          <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="hidden md:block">
          <h1 class="text-lg font-bold text-gray-900">千川直播带货</h1>
          <p class="text-xs text-gray-500">Qianchuan Live E-commerce</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button class="relative flex items-center justify-center w-10 h-10 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <span class="absolute right-1.5 top-1.5 h-2 w-2 rounded-full bg-red-500"></span>
        </button>
        <div class="relative">
          <button class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-100 transition-colors">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-red-500 to-orange-500 text-white">
              <span class="text-sm font-medium">商</span>
            </div>
            <span class="hidden text-sm font-medium md:inline-block">商家中心</span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <div class="flex">
    <aside class="w-64 bg-white border-r border-gray-200 min-h-[calc(100vh-64px)] sticky top-16">
      <nav id="main-nav" class="p-4 space-y-6"></nav>
    </aside>

    <main class="flex-1 p-8">
      <div class="max-w-7xl mx-auto space-y-6">
<div class="flex">
        <!-- Sidebar -->
        <aside class="w-64 bg-white border-r border-gray-200 min-h-[calc(100vh-64px)] sticky top-16">
            <nav class="p-4 space-y-6">
                <div>
                    <h3 class="mb-3 px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">推广投放</h3>
                    <ul class="space-y-1">
                        <li>
                            <a href="promotions.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z"/>
                                </svg>
                                <span>推广计划</span>
                            </a>
                        </li>
                        <li>
                            <a href="creatives.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg bg-gradient-to-r from-red-500 to-orange-500 text-white font-medium shadow-sm">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/>
                                </svg>
                                <span>创意管理</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
        </aside>

        <!-- Main Content -->
        <main class="flex-1 p-8">
            <div class="max-w-7xl mx-auto space-y-6">
                <!-- Breadcrumb -->
                <div class="flex items-center text-sm text-gray-500">
                    <a href="dashboard.html" class="hover:text-blue-600">数据中心</a>
                    <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                    <a href="creatives.html" class="hover:text-blue-600">创意管理</a>
                    <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                    <span class="text-gray-900">创意详情</span>
                </div>

                <!-- Page Header -->
                <div class="flex items-center justify-between">
                    <div>
                        <h1 class="text-3xl font-bold text-gray-900">创意详情</h1>
                        <p class="mt-2 text-gray-600">创意ID: CREATIVE10023456</p>
                    </div>
                    <div class="flex gap-2">
                        <button class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">
                            <span>编辑创意</span>
                        </button>
                        <button class="px-4 py-2 bg-gradient-to-r from-red-500 to-orange-500 text-white rounded-lg hover:from-red-600 hover:to-orange-600 transition-all shadow-sm">
                            <span>复制创意</span>
                        </button>
                    </div>
                </div>

                <!-- Status Card -->
                <div class="bg-white rounded-lg border border-gray-200 p-6">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center gap-4">
                            <div class="flex items-center gap-2">
                                <span class="status-indicator w-3 h-3 rounded-full bg-green-500"></span>
                                <span class="text-lg font-semibold text-gray-900">投放中</span>
                            </div>
                            <div class="h-6 w-px bg-gray-300"></div>
                            <div>
                                <p class="text-sm text-gray-500">审核状态 (audit_status)</p>
                                <p class="text-sm font-medium text-green-600">✅ 审核通过</p>
                            </div>
                            <div class="h-6 w-px bg-gray-300"></div>
                            <div>
                                <p class="text-sm text-gray-500">创建时间</p>
                                <p class="text-sm font-medium text-gray-900">2024-01-15 14:32:15</p>
                            </div>
                            <div class="h-6 w-px bg-gray-300"></div>
                            <div>
                                <p class="text-sm text-gray-500">所属计划</p>
                                <p class="text-sm font-medium text-blue-600 hover:underline cursor-pointer">美妆直播间-推广计划01</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Key Metrics -->
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <div class="flex items-center justify-between mb-4">
                            <p class="text-sm font-medium text-gray-600">展示量</p>
                            <div class="p-2 rounded-lg bg-blue-50">
                                <svg class="h-5 w-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                                </svg>
                            </div>
                        </div>
                        <p class="text-3xl font-bold text-gray-900">523,456</p>
                        <div class="flex items-center gap-2 text-sm mt-2">
                            <span class="text-green-600 font-medium">+18.5%</span>
                            <span class="text-gray-600">vs 昨日</span>
                        </div>
                    </div>

                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <div class="flex items-center justify-between mb-4">
                            <p class="text-sm font-medium text-gray-600">点击量</p>
                            <div class="p-2 rounded-lg bg-purple-50">
                                <svg class="h-5 w-5 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 15l-2 5L9 9l11 4-5 2zm0 0l5 5M7.188 2.239l.777 2.897M5.136 7.965l-2.898-.777M13.95 4.05l-2.122 2.122m-5.657 5.656l-2.12 2.122"/>
                                </svg>
                            </div>
                        </div>
                        <p class="text-3xl font-bold text-gray-900">28,034</p>
                        <div class="flex items-center gap-2 text-sm mt-2">
                            <span class="text-green-600 font-medium">+22.3%</span>
                            <span class="text-gray-600">CTR: 5.35%</span>
                        </div>
                    </div>

                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <div class="flex items-center justify-between mb-4">
                            <p class="text-sm font-medium text-gray-600">转化数</p>
                            <div class="p-2 rounded-lg bg-green-50">
                                <svg class="h-5 w-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                        </div>
                        <p class="text-3xl font-bold text-gray-900">1,245</p>
                        <div class="flex items-center gap-2 text-sm mt-2">
                            <span class="text-green-600 font-medium">+15.2%</span>
                            <span class="text-gray-600">转化率: 4.44%</span>
                        </div>
                    </div>

                    <div class="bg-white rounded-lg border border-gray-200 p-6">
                        <div class="flex items-center justify-between mb-4">
                            <p class="text-sm font-medium text-gray-600">消耗金额</p>
                            <div class="p-2 rounded-lg bg-orange-50">
                                <svg class="h-5 w-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                </svg>
                            </div>
                        </div>
                        <p class="text-3xl font-bold text-gray-900">¥2,345</p>
                        <div class="flex items-center gap-2 text-sm mt-2">
                            <span class="text-gray-600">CPC: ¥0.084</span>
                        </div>
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
                    <!-- Creative Preview -->
                    <div class="lg:col-span-1 space-y-6">
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4">创意素材预览</h2>
                            
                            <!-- Video Preview -->
                            <div class="relative aspect-[9/16] bg-gradient-to-br from-gray-100 to-gray-200 rounded-lg overflow-hidden mb-4">
                                <div class="absolute inset-0 flex items-center justify-center">
                                    <svg class="w-16 h-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                    </svg>
                                </div>
                                <div class="absolute bottom-0 left-0 right-0 bg-gradient-to-t from-black/60 to-transparent p-4">
                                    <p class="text-white text-sm font-medium">视频创意 - 15s</p>
                                    <p class="text-white/80 text-xs">1080x1920</p>
                                </div>
                            </div>

                            <!-- Creative Info -->
                            <div class="space-y-3">
                                <div>
                                    <p class="text-xs text-gray-500 mb-1">创意标题 (title)</p>
                                    <p class="text-sm font-medium text-gray-900">【限时特价】冬季保暖羽绒服，温暖过冬！</p>
                                </div>
                                <div>
                                    <p class="text-xs text-gray-500 mb-1">创意类型 (creative_type)</p>
                                    <p class="text-sm font-medium text-gray-900">视频创意 (VIDEO)</p>
                                </div>
                                <div>
                                    <p class="text-xs text-gray-500 mb-1">素材ID (material_id)</p>
                                    <p class="text-sm font-mono text-gray-700">MAT987654321</p>
                                </div>
                                <div>
                                    <p class="text-xs text-gray-500 mb-1">视频时长</p>
                                    <p class="text-sm font-medium text-gray-900">15秒</p>
                                </div>
                            </div>
                        </div>

                        <!-- Creative Tags -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4">创意标签</h2>
                            <div class="flex flex-wrap gap-2">
                                <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-medium">服饰</span>
                                <span class="px-3 py-1 bg-purple-100 text-purple-700 rounded-full text-sm font-medium">羽绒服</span>
                                <span class="px-3 py-1 bg-pink-100 text-pink-700 rounded-full text-sm font-medium">冬季</span>
                                <span class="px-3 py-1 bg-orange-100 text-orange-700 rounded-full text-sm font-medium">特价</span>
                                <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-sm font-medium">高转化</span>
                            </div>
                        </div>
                    </div>

                    <!-- Performance Data -->
                    <div class="lg:col-span-2 space-y-6">
                        <!-- Performance Chart -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4">近7日效果趋势</h2>
                            <div class="h-80">
                                <canvas id="performanceChart"></canvas>
                            </div>
                        </div>

                        <!-- Targeting Info -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4">定向设置 (audience_targeting)</h2>
                            <div class="grid grid-cols-2 gap-6">
                                <div>
                                    <p class="text-sm font-medium text-gray-700 mb-2">年龄范围</p>
                                    <p class="text-sm text-gray-600">18-45岁</p>
                                </div>
                                <div>
                                    <p class="text-sm font-medium text-gray-700 mb-2">性别</p>
                                    <p class="text-sm text-gray-600">女性为主</p>
                                </div>
                                <div>
                                    <p class="text-sm font-medium text-gray-700 mb-2">地域</p>
                                    <p class="text-sm text-gray-600">一线、二线城市</p>
                                </div>
                                <div>
                                    <p class="text-sm font-medium text-gray-700 mb-2">兴趣标签</p>
                                    <p class="text-sm text-gray-600">时尚、购物、穿搭</p>
                                </div>
                            </div>
                        </div>

                        <!-- Associated Products -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4">关联商品</h2>
                            <div class="space-y-3">
                                <div class="flex items-center gap-4 p-3 border border-gray-200 rounded-lg hover:bg-gray-50">
                                    <div class="w-16 h-16 bg-gradient-to-br from-pink-100 to-orange-100 rounded flex-shrink-0"></div>
                                    <div class="flex-1">
                                        <p class="text-sm font-medium text-gray-900">[限时特价] 冬季保暖羽绒服</p>
                                        <p class="text-xs text-gray-500 mt-1">商品ID: PROD123456</p>
                                    </div>
                                    <div class="text-right">
                                        <p class="text-sm font-bold text-orange-600">¥299</p>
                                        <p class="text-xs text-gray-500 line-through">¥599</p>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Audit History -->
                        <div class="bg-white rounded-lg border border-gray-200 p-6">
                            <h2 class="text-lg font-semibold text-gray-900 mb-4">审核记录 (audit_log)</h2>
                            <div class="space-y-4">
                                <div class="flex items-start gap-3">
                                    <div class="flex-shrink-0 w-2 h-2 mt-2 rounded-full bg-green-500"></div>
                                    <div class="flex-1">
                                        <div class="flex items-center justify-between mb-1">
                                            <p class="text-sm font-medium text-gray-900">审核通过</p>
                                            <p class="text-xs text-gray-500">2024-01-15 14:35:22</p>
                                        </div>
                                        <p class="text-sm text-gray-600">创意内容符合平台规范，已通过审核</p>
                                    </div>
                                </div>
                                <div class="flex items-start gap-3">
                                    <div class="flex-shrink-0 w-2 h-2 mt-2 rounded-full bg-blue-500"></div>
                                    <div class="flex-1">
                                        <div class="flex items-center justify-between mb-1">
                                            <p class="text-sm font-medium text-gray-900">提交审核</p>
                                            <p class="text-xs text-gray-500">2024-01-15 14:32:15</p>
                                        </div>
                                        <p class="text-sm text-gray-600">创意已提交，等待平台审核</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
              </div>
    </div>
  </main>
  </div>
    </div>

    <script>
        // Performance Chart
        const ctx = document.getElementById('performanceChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['01/09', '01/10', '01/11', '01/12', '01/13', '01/14', '01/15'],
                datasets: [
                    {
                        label: '展示量',
                        data: [420000, 445000, 468000, 485000, 502000, 518000, 523456],
                        borderColor: 'rgb(59, 130, 246)',
                        backgroundColor: 'rgba(59, 130, 246, 0.1)',
                        tension: 0.4,
                        fill: true,
                        yAxisID: 'y'
                    },
                    {
                        label: '点击量',
                        data: [22000, 23500, 24800, 25600, 26500, 27200, 28034],
                        borderColor: 'rgb(147, 51, 234)',
                        backgroundColor: 'rgba(147, 51, 234, 0.1)',
                        tension: 0.4,
                        fill: true,
                        yAxisID: 'y'
                    },
                    {
                        label: '转化数',
                        data: [980, 1050, 1120, 1150, 1185, 1220, 1245],
                        borderColor: 'rgb(16, 185, 129)',
                        backgroundColor: 'rgba(16, 185, 129, 0.1)',
                        tension: 0.4,
                        fill: false,
                        yAxisID: 'y1'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: {
                    mode: 'index',
                    intersect: false,
                },
                plugins: {
                    legend: {
                        position: 'top',
                    },
                },
                scales: {
                    y: {
                        type: 'linear',
                        display: true,
                        position: 'left',
                        title: {
                            display: true,
                            text: '展示量 / 点击量'
                        }
                    },
                    y1: {
                        type: 'linear',
                        display: true,
                        position: 'right',
                        title: {
                            display: true,
                            text: '转化数'
                        },
                        grid: {
                            drawOnChartArea: false,
                        },
                    }
                }
            }
        });
    </script>
  <script src="nav-component.js"></script>
</body>
</html>
