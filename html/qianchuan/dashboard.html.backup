    <script>
        // Update time
        setInterval(() => {
            const now = new Date();
            document.getElementById('update-time').textContent = now.toLocaleTimeString('zh-CN');
        }, 1000);

        // Chart
        const ctx = document.getElementById('trendChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['12/03', '12/04', '12/05', '12/06', '12/07', '12/08', '12/09'],
                datasets: [
                    {
                        label: 'GMV (万元)',
                        data: [8.5, 9.2, 10.1, 9.8, 11.2, 12.3, 12.8],
                        borderColor: 'rgb(249, 115, 22)',
                        backgroundColor: 'rgba(249, 115, 22, 0.1)',
                        tension: 0.4,
                        fill: true,
                        yAxisID: 'y'
                    },
                    {
                        label: '观看人数 (万)',
