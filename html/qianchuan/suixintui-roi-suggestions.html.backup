<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <link rel="stylesheet" href="./design-system.css">
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>随心推ROI目标建议 - 千川直播带货平台</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50">
      <!-- Header -->
  <header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-gray-200">
    <div class="flex h-16 items-center justify-between px-6">
      <div class="flex items-center gap-3">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-gradient-to-br from-red-500 to-orange-500">
          <svg class="h-6 w-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="hidden md:block">
          <h1 class="text-lg font-bold text-gray-900">千川直播带货</h1>
          <p class="text-xs text-gray-500">Qianchuan Live E-commerce</p>
        </div>
      </div>
      <div class="flex items-center gap-3">
        <button class="relative flex items-center justify-center w-10 h-10 rounded-lg hover:bg-gray-100 transition-colors">
          <svg class="h-5 w-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
          </svg>
          <span class="absolute right-1.5 top-1.5 h-2 w-2 rounded-full bg-red-500"></span>
        </button>
        <div class="relative">
          <button class="flex items-center gap-2 px-3 py-2 rounded-lg hover:bg-gray-100 transition-colors">
            <div class="flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-red-500 to-orange-500 text-white">
              <span class="text-sm font-medium">商</span>
            </div>
            <span class="hidden text-sm font-medium md:inline-block">商家中心</span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <div class="flex">
    <aside class="w-64 bg-white border-r border-gray-200 min-h-[calc(100vh-64px)] sticky top-16">
      <nav id="main-nav" class="p-4 space-y-6"></nav>
    </aside>

    <main class="flex-1 p-8">
      <div class="max-w-7xl mx-auto space-y-6">
<div class="flex">
        <aside class="w-64 bg-white border-r border-gray-200 min-h-[calc(100vh-64px)] sticky top-16">
            <nav class="p-4 space-y-6">
                <div>
                    <h3 class="mb-3 px-3 text-xs font-semibold text-gray-500 uppercase tracking-wider">随心推</h3>
                    <ul class="space-y-1">
                        <li>
                            <a href="suixintui.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <span>随心推订单</span>
                            </a>
                        </li>
                        <li>
                            <a href="suixintui-bid-suggestions.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg text-gray-700 hover:bg-gray-100 transition-all">
                                <span>出价建议</span>
                            </a>
                        </li>
                        <li>
                            <a href="suixintui-roi-suggestions.html" class="group flex items-center gap-3 px-3 py-2.5 rounded-lg bg-gradient-to-r from-red-500 to-orange-500 text-white font-medium shadow-sm">
                                <span>ROI目标建议</span>
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
        </aside>

        <main class="flex-1 p-8">
            <div class="max-w-4xl mx-auto space-y-6">
                <div class="flex items-center text-sm text-gray-500">
                    <a href="dashboard.html" class="hover:text-blue-600">数据中心</a>
                    <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                    <a href="suixintui.html" class="hover:text-blue-600">随心推</a>
                    <svg class="w-4 h-4 mx-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                    </svg>
                    <span class="text-gray-900">ROI目标建议</span>
                </div>

                <div>
                    <h1 class="text-3xl font-bold text-gray-900">随心推ROI目标建议</h1>
                    <p class="mt-2 text-gray-600">获取智能推荐的ROI目标，优化投放效果 (api/qianchuan/aweme/SuggestRoiGoal)</p>
                </div>

                <!-- Info Card -->
                <div class="bg-blue-50 border-l-4 border-blue-400 p-4">
                    <div class="flex">
                        <svg class="h-5 w-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                        <div class="ml-3">
                            <h3 class="text-sm font-medium text-blue-800">功能说明</h3>
                            <div class="mt-2 text-sm text-blue-700">
                                <ul class="list-disc list-inside space-y-1">
                                    <li>根据历史数据和行业情况，智能推荐合适的ROI目标</li>
                                    <li>帮助优化投放成本，提高投资回报率</li>
                                    <li>支持不同推广场景的ROI目标建议</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Input Form -->
                <div class="bg-white rounded-lg border border-gray-200 p-6">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">输入参数</h2>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                广告账户ID (advertiser_id) <span class="text-red-500">*</span>
                            </label>
                            <input type="text" placeholder="请输入广告账户ID" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                抖音号ID (aweme_id) <span class="text-red-500">*</span>
                            </label>
                            <input type="text" placeholder="请输入抖音号ID" class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                推广目标类型 (external_action)
                            </label>
                            <select class="w-full px-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                                <option value="">请选择推广目标</option>
                                <option value="AD_CONVERT_TYPE_LIVE_SUCCESSORDER_ACTION">直播间成交</option>
                                <option value="AD_CONVERT_TYPE_LIVE_ENTER_ACTION">直播间进入</option>
                                <option value="AD_CONVERT_TYPE_SHOPPING">商品购买</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                每日预算 (budget)
                            </label>
                            <div class="relative">
                                <span class="absolute left-3 top-2 text-gray-500">¥</span>
                                <input type="number" placeholder="100" class="w-full pl-8 pr-3 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500">
                            </div>
                        </div>
                    </div>

                    <div class="mt-6 flex justify-end gap-3">
                        <button class="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg hover:bg-gray-50 transition-colors">
                            重置
                        </button>
                        <button class="px-4 py-2 bg-gradient-to-r from-red-500 to-orange-500 text-white rounded-lg hover:from-red-600 hover:to-orange-600 transition-all shadow-sm">
                            获取建议
                        </button>
                    </div>
                </div>

                <!-- Suggestion Result -->
                <div class="bg-white rounded-lg border border-gray-200 p-6">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">ROI目标建议</h2>
                    
                    <div class="bg-gradient-to-br from-orange-50 to-red-50 border-2 border-orange-200 rounded-lg p-6 mb-6">
                        <div class="flex items-center justify-between mb-4">
                            <div>
                                <p class="text-sm text-gray-600 mb-1">建议ROI目标</p>
                                <p class="text-5xl font-bold text-orange-600">4.5</p>
                            </div>
                            <div class="p-4 rounded-full bg-orange-100">
                                <svg class="w-12 h-12 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
                                </svg>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 text-sm text-gray-700">
                            <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
                            </svg>
                            <span>基于历史数据和行业基准推荐</span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
                        <div class="p-4 border border-gray-200 rounded-lg">
                            <p class="text-xs text-gray-500 mb-1">最低建议ROI</p>
                            <p class="text-2xl font-bold text-gray-900">3.5</p>
                        </div>
                        <div class="p-4 border-2 border-orange-300 bg-orange-50 rounded-lg">
                            <p class="text-xs text-gray-500 mb-1">推荐ROI</p>
                            <p class="text-2xl font-bold text-orange-600">4.5</p>
                        </div>
                        <div class="p-4 border border-gray-200 rounded-lg">
                            <p class="text-xs text-gray-500 mb-1">理想ROI</p>
                            <p class="text-2xl font-bold text-gray-900">5.8</p>
                        </div>
                    </div>

                    <div class="space-y-3">
                        <div>
                            <h3 class="text-sm font-semibold text-gray-900 mb-2">建议说明</h3>
                            <ul class="space-y-2 text-sm text-gray-600">
                                <li class="flex items-start gap-2">
                                    <svg class="w-4 h-4 text-green-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                    <span>该ROI目标适合您当前的投放场景和预算水平</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <svg class="w-4 h-4 text-green-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                    <span>建议在投放初期使用推荐值，后续根据实际效果调整</span>
                                </li>
                                <li class="flex items-start gap-2">
                                    <svg class="w-4 h-4 text-green-600 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                                    </svg>
                                    <span>该行业平均ROI为4.2，您的目标略高于行业平均水平</span>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>

                <!-- History -->
                <div class="bg-white rounded-lg border border-gray-200 p-6">
                    <h2 class="text-lg font-semibold text-gray-900 mb-4">历史查询记录</h2>
                    <div class="space-y-3">
                        <div class="flex items-center justify-between p-3 border border-gray-200 rounded-lg hover:bg-gray-50">
                            <div>
                                <p class="text-sm font-medium text-gray-900">美妆旗舰店 - 直播间成交</p>
                                <p class="text-xs text-gray-500 mt-1">2024-01-15 14:32:15</p>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-semibold text-orange-600">ROI 4.5</p>
                                <button class="text-xs text-blue-600 hover:text-blue-700 mt-1">应用</button>
                            </div>
                        </div>
                        <div class="flex items-center justify-between p-3 border border-gray-200 rounded-lg hover:bg-gray-50">
                            <div>
                                <p class="text-sm font-medium text-gray-900">服饰专卖店 - 商品购买</p>
                                <p class="text-xs text-gray-500 mt-1">2024-01-14 10:15:32</p>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-semibold text-orange-600">ROI 5.2</p>
                                <button class="text-xs text-blue-600 hover:text-blue-700 mt-1">应用</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
              </div>
    </div>
  </main>
  </div>
    </div>
  <script src="nav-component.js"></script>
</body>
</html>
