  </main>
  </div>
    </div>

    <script>
        // GMV Trend Chart
        const gmvChart = echarts.init(document.getElementById('gmvChart'));
        gmvChart.setOption({
            tooltip: { trigger: 'axis' },
            grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },
            xAxis: {
                type: 'category',
                boundaryGap: false,
                data: ['00:00', '02:00', '04:00', '06:00', '08:00', '10:00', '12:00', '14:00', '16:00', '18:00', '20:00', '22:00']
            },
            yAxis: { type: 'value', name: 'GMV (元)' },
            series: [{
                name: 'GMV',
                type: 'line',
                smooth: true,
                areaStyle: {
                    color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                        { offset: 0, color: 'rgba(239, 68, 68, 0.3)' },
                        { offset: 1, color: 'rgba(249, 115, 22, 0.1)' }
                    ])
                },
                lineStyle: { color: '#F97316', width: 3 },
                itemStyle: { color: '#EF4444' },
                data: [1200, 800, 600, 900, 2300, 3800, 5200, 6800, 8500, 12000, 18500, 15200]
            }]
        });

        // Viewers Trend Chart
        const viewersChart = echarts.init(document.getElementById('viewersChart'));
        viewersChart.setOption({
            tooltip: { trigger: 'axis' },
            grid: { left: '3%', right: '4%', bottom: '3%', containLabel: true },
            xAxis: {
                type: 'category',
                boundaryGap: false,
                data: ['00:00', '02:00', '04:00', '06:00', '08:00', '10:00', '12:00', '14:00', '16:00', '18:00', '20:00', '22:00']
            },
            yAxis: { type: 'value', name: '人数' },
            series: [{
                name: '观看人数',
                type: 'line',
                smooth: true,
                areaStyle: {
                    color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                        { offset: 0, color: 'rgba(59, 130, 246, 0.3)' },
                        { offset: 1, color: 'rgba(99, 102, 241, 0.1)' }
                    ])
                },
                lineStyle: { color: '#3B82F6', width: 3 },
                itemStyle: { color: '#6366F1' },
                data: [1200, 900, 600, 800, 2100, 3500, 4800, 6200, 7800, 10500, 12300, 9800]
            }]
        });

        // Traffic Sources Chart
        const trafficChart = echarts.init(document.getElementById('trafficChart'));
        trafficChart.setOption({
            tooltip: { trigger: 'item' },
            legend: { orient: 'vertical', left: 'left' },
            series: [{
                name: '流量来源',
                type: 'pie',
                radius: '60%',
                data: [
                    { value: 4235, name: '推荐页', itemStyle: { color: '#EF4444' } },
                    { value: 2856, name: '搜索', itemStyle: { color: '#F97316' } },
                    { value: 1892, name: '粉丝', itemStyle: { color: '#3B82F6' } },
                    { value: 1456, name: '付费推广', itemStyle: { color: '#8B5CF6' } },
                    { value: 982, name: '其他', itemStyle: { color: '#6B7280' } }
                ],
                emphasis: {
                    itemStyle: {
                        shadowBlur: 10,
                        shadowOffsetX: 0,
                        shadowColor: 'rgba(0, 0, 0, 0.5)'
                    }
                }
            }]
        });

        // Responsive resize
        window.addEventListener('resize', () => {
            gmvChart.resize();
            viewersChart.resize();
            trafficChart.resize();
        });
    </script>
  <script src="nav-component.js"></script>
</body>
